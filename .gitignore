# ------------------------------------
# 1. DEPENDENCY FOLDERS (REQUIRED)
# ------------------------------------
# Node module folders in both subdirectories
/frontend/node_modules/
/server/node_modules/
/node_modules
# ------------------------------------
# 2. ENVIRONMENT/SECRET FILES (CRITICAL)
# ------------------------------------
# This ignores all .env files globally, which is the safest default.
.env
# Ignores specific local environment files that React/Vite might use
.env.local
.env.*.local

# ------------------------------------
# 3. BUILD ARTIFACTS
# ------------------------------------
# Production build output from Vite/React
/frontend/dist/
/frontend/build/

# ------------------------------------
# 4. OPERATING SYSTEM & EDITOR FILES
# ------------------------------------
.DS_Store
Thumbs.db
*.log
/frontend/.vscode/ # Ignore editor settings if they change frequently